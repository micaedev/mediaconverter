# Video Converter — ortam değişkenleri

# Yükleme boyutu limiti (bayt). 0 = sınırsız
MAX_UPLOAD_BYTES=53687091200

# Depolama birimleri: id:konteyner_yolu:etiket|pc_yolu
STORAGE_VOLUMES=default:/videos:Kaynak (yüklemeler)|./data/videos;output:/output:Dönüştürülmüş çıktı|./data/output

# Disk gezintisi kökleri (sihirbaz için)
STORAGE_BROWSE_ROOTS=output:/output:Çıktı klasörü|./data/output;media:/host/media:Media diski|/media;mnt:/host/mnt:Mount (/mnt)|/mnt;extra:/host/extra:Ek disk|/host/extra

# Host kullanıcı — oluşturulan dosyalar bu UID/GID ile sahiplenilir
PUID=1000
PGID=1000

# Ek disk mount (isteğe bağlı)
# STORAGE_EXTRA_HOST_PATH=/path/on/host
